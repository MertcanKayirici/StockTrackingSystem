@model StockTrackingSystem.Models.Product
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    // Page title
    ViewData["Title"] = "Ürün Düzenle";

    // Category dropdown data
    var categories = ViewBag.Categories as List<SelectListItem> ?? new List<SelectListItem>();
}

<style>
    /* =========================
           PAGE BACKGROUND
        ========================= */
    body {
        background: #f8fafc;
    }

    /* =========================
           MAIN CARDS
        ========================= */
    .page-card,
    .form-card,
    .preview-card {
        border: 0;
        border-radius: 24px;
        background: #ffffff;
        box-shadow: 0 10px 30px rgba(15, 23, 42, 0.06);
    }

    .page-card {
        padding: 30px 32px;
        margin-bottom: 24px;
    }

    /* =========================
           PAGE HEADER
        ========================= */
    .page-title {
        font-size: 2.1rem;
        font-weight: 800;
        color: #0f172a;
        margin-bottom: 6px;
    }

    .page-subtitle {
        color: #64748b;
        font-size: 1.02rem;
        margin-bottom: 0;
    }

    .back-btn {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        border-radius: 999px;
        padding: 12px 22px;
        font-weight: 700;
    }

    /* =========================
           CARD STRUCTURE
        ========================= */
    .form-card,
    .preview-card {
        overflow: hidden;
    }

    @@media (min-width: 1200px) {
        .form-card {
            height: 100%;
        }
    }

    .card-header-custom {
        padding: 24px 28px 14px 28px;
        border-bottom: 1px solid #f1f5f9;
    }

    .card-title-custom {
        font-size: 1.12rem;
        font-weight: 800;
        color: #0f172a;
        margin-bottom: 4px;
    }

    .card-subtitle-custom {
        color: #64748b;
        font-size: 0.93rem;
        margin-bottom: 0;
    }

    .card-body-custom {
        padding: 24px 28px 28px 28px;
    }

    /* =========================
           FORM ELEMENTS
        ========================= */
    .form-label {
        font-size: 0.95rem;
        font-weight: 700;
        color: #334155;
        margin-bottom: 10px;
    }

    .form-control,
    .form-select {
        min-height: 54px;
        border-radius: 16px;
        border: 1px solid #dbe2ea;
        padding-left: 16px;
        padding-right: 16px;
        background: #fff;
        font-size: 1rem;
        box-shadow: none;
        transition: all 0.2s ease;
    }

    textarea.form-control {
        min-height: 130px;
        padding-top: 14px;
        resize: vertical;
    }

    .form-control:focus,
    .form-select:focus {
        border-color: #3b82f6;
        box-shadow: 0 0 0 0.22rem rgba(59, 130, 246, 0.12);
    }

    input[type="file"].form-control {
        padding-top: 12px;
        padding-bottom: 12px;
    }

    .text-danger {
        font-size: 0.88rem;
        font-weight: 600;
        margin-top: 6px;
        display: block;
    }

    /* =========================
           MODERN SWITCH
        ========================= */
    .modern-switch-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        padding: 16px 18px;
        border: 1px solid #e2e8f0;
        border-radius: 18px;
        background: #f8fafc;
    }

    .modern-switch-info {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .modern-switch-title {
        font-weight: 800;
        color: #0f172a;
        font-size: 0.98rem;
    }

    .modern-switch-subtitle {
        color: #64748b;
        font-size: 0.9rem;
    }

    .modern-switch {
        position: relative;
        display: inline-block;
        width: 56px;
        height: 30px;
        margin: 0;
        flex-shrink: 0;
    }

        .modern-switch input {
            opacity: 0;
            width: 0;
            height: 0;
        }

        .modern-switch .slider {
            position: absolute;
            inset: 0;
            cursor: pointer;
            background: #e5e7eb;
            transition: .25s ease;
            border-radius: 999px;
            box-shadow: inset 0 0 0 1px rgba(15, 23, 42, 0.06);
        }

            .modern-switch .slider:before {
                content: "";
                position: absolute;
                height: 22px;
                width: 22px;
                left: 4px;
                top: 4px;
                background: white;
                transition: .25s ease;
                border-radius: 50%;
                box-shadow: 0 4px 10px rgba(15, 23, 42, 0.15);
            }

        .modern-switch input:checked + .slider {
            background: linear-gradient(135deg, #2563eb, #3b82f6);
        }

            .modern-switch input:checked + .slider:before {
                transform: translateX(26px);
            }

    /* =========================
           PREVIEW CARD
        ========================= */
    .preview-box {
        border: 1px dashed #dbe2ea;
        border-radius: 22px;
        background: #f8fafc;
        padding: 28px 24px;
        text-align: center;
        min-height: 280px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
    }

    .preview-image {
        width: 160px;
        height: 160px;
        object-fit: cover;
        border-radius: 24px;
        border: 3px solid #e2e8f0;
        background: #ffffff;
        box-shadow: 0 10px 24px rgba(15, 23, 42, 0.08);
        margin-bottom: 16px;
    }

    .preview-placeholder {
        width: 160px;
        height: 160px;
        margin: 0 auto 16px auto;
        border-radius: 24px;
        border: 3px solid #e2e8f0;
        background: #ffffff;
        color: #94a3b8;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        box-shadow: 0 10px 24px rgba(15, 23, 42, 0.08);
    }

    .preview-title {
        font-size: 1.08rem;
        font-weight: 800;
        color: #0f172a;
        margin-bottom: 6px;
        word-break: break-word;
    }

    .preview-text {
        color: #64748b;
        font-size: 0.93rem;
        margin-bottom: 0;
        line-height: 1.6;
        max-width: 360px;
        word-break: break-word;
    }

    /* =========================
           INFO LIST
        ========================= */
    .info-list {
        display: flex;
        flex-direction: column;
        gap: 14px;
    }

    .info-item {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 14px 16px;
        border-radius: 18px;
        border: 1px solid #eef2f7;
        background: #f8fafc;
    }

    .info-icon {
        width: 46px;
        height: 46px;
        border-radius: 14px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: rgba(37, 99, 235, 0.10);
        color: #2563eb;
        font-size: 1.05rem;
        flex-shrink: 0;
    }

    .info-label {
        font-size: 0.86rem;
        color: #64748b;
        margin-bottom: 2px;
    }

    .info-value {
        font-size: 0.96rem;
        font-weight: 800;
        color: #0f172a;
        word-break: break-word;
    }

    /* =========================
           ACTION BAR
        ========================= */
    .action-bar {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-top: 6px;
    }

    .save-btn,
    .cancel-btn {
        min-height: 52px;
        border-radius: 16px;
        padding: 0 24px;
        font-weight: 700;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        line-height: 1;
    }

    .save-btn {
        min-width: 190px;
    }

    .cancel-btn {
        min-width: 140px;
        text-decoration: none;
    }

    .validation-summary-errors ul {
        margin: 0 0 16px 0;
        padding-left: 18px;
        color: #dc2626;
        font-weight: 600;
    }

    /* =========================
           RESPONSIVE
        ========================= */
    @@media (max-width: 1199.98px) {
        .page-card {
            padding: 24px;
        }

        .card-header-custom {
            padding: 20px 22px 12px 22px;
        }

        .card-body-custom {
            padding: 20px 22px 24px 22px;
        }
    }

    @@media (max-width: 767.98px) {
        .page-title {
            font-size: 1.7rem;
        }

        .page-card {
            padding: 20px;
        }

        .card-header-custom {
            padding: 18px 18px 12px 18px;
        }

        .card-body-custom {
            padding: 18px 18px 20px 18px;
        }

        .modern-switch-row {
            align-items: flex-start;
        }

        .action-bar {
            flex-direction: column;
        }

        .save-btn,
        .cancel-btn,
        .back-btn {
            width: 100%;
            justify-content: center;
        }

        .preview-image,
        .preview-placeholder {
            width: 130px;
            height: 130px;
        }

        .preview-box {
            min-height: 240px;
            padding: 22px 18px;
        }
    }
</style>

<div class="container py-4">
    <!-- =========================
         PAGE HEADER
    ========================= -->
    <div class="page-card">
        <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
            <div>
                <h1 class="page-title">Ürün Düzenle</h1>
                <p class="page-subtitle">Ürün bilgilerini güncelle, stok ve durum alanlarını kolayca yönet.</p>
            </div>

            <a asp-action="Index" class="btn btn-outline-dark back-btn">
                <i class="bi bi-arrow-left"></i>Listeye Dön
            </a>
        </div>
    </div>

    <!-- =========================
         EDIT FORM
    ========================= -->
    <form asp-action="Edit" method="post" enctype="multipart/form-data">
        <input asp-for="Id" type="hidden" />
        <input asp-for="CreatedDate" type="hidden" />
        <input asp-for="ImageUrl" type="hidden" />

        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="row g-4">
            <!-- Main form column -->
            <div class="col-xl-8">
                <div class="form-card">
                    <div class="card-header-custom">
                        <div class="card-title-custom">Ürün Bilgileri</div>
                        <p class="card-subtitle-custom">Temel alanları güncelleyerek ürün kaydını düzenleyebilirsin.</p>
                    </div>

                    <div class="card-body-custom">
                        <div class="row g-4">
                            <!-- Product name -->
                            <div class="col-md-6">
                                <label asp-for="Name" class="form-label">Ürün Adı</label>
                                <input asp-for="Name" class="form-control" placeholder="Örn: Logitech MX Master 3" />
                                <span asp-validation-for="Name" class="text-danger"></span>
                            </div>

                            <!-- Category -->
                            <div class="col-md-6">
                                <label asp-for="CategoryId" class="form-label">Kategori</label>
                                <select asp-for="CategoryId" asp-items="categories" class="form-select">
                                    <option value="">Kategori Seçin</option>
                                </select>
                                <span asp-validation-for="CategoryId" class="text-danger"></span>
                            </div>

                            <!-- Unit price -->
                            <div class="col-md-6">
                                <label asp-for="UnitPrice" class="form-label">Birim Fiyat</label>
                                <input asp-for="UnitPrice" class="form-control" type="number" step="0.01" placeholder="0.00" />
                                <span asp-validation-for="UnitPrice" class="text-danger"></span>
                            </div>

                            <!-- Stock quantity -->
                            <div class="col-md-6">
                                <label asp-for="StockQuantity" class="form-label">Stok Miktarı</label>
                                <input asp-for="StockQuantity" class="form-control" type="number" placeholder="0" />
                                <span asp-validation-for="StockQuantity" class="text-danger"></span>
                            </div>

                            <!-- Critical stock level -->
                            <div class="col-md-6">
                                <label asp-for="CriticalStockLevel" class="form-label">Kritik Stok Seviyesi</label>
                                <input asp-for="CriticalStockLevel" class="form-control" type="number" placeholder="Örn: 5" />
                                <span asp-validation-for="CriticalStockLevel" class="text-danger"></span>
                            </div>

                            <!-- Image upload -->
                            <div class="col-md-6">
                                <label class="form-label">Ürün Görseli</label>
                                <input type="file" name="imageFile" id="imageFile" class="form-control" accept="image/*" />
                            </div>

                            <!-- Description -->
                            <div class="col-12">
                                <label asp-for="Description" class="form-label">Açıklama</label>
                                <textarea asp-for="Description" class="form-control" placeholder="Ürün hakkında kısa açıklama yaz..."></textarea>
                                <span asp-validation-for="Description" class="text-danger"></span>
                            </div>

                            <!-- Active status -->
                            <div class="col-12">
                                <div class="modern-switch-row">
                                    <div class="modern-switch-info">
                                        <div class="modern-switch-title">Ürün Durumu</div>
                                        <div class="modern-switch-subtitle">Aktif ürünler listelerde görünür ve işlem almaya devam eder.</div>
                                    </div>

                                    <label class="modern-switch">
                                        <input asp-for="IsActive" />
                                        <span class="slider"></span>
                                    </label>
                                </div>
                            </div>
                        </div>

                        <!-- Form actions -->
                        <div class="action-bar mt-4">
                            <button type="submit" class="btn btn-primary save-btn">
                                <i class="bi bi-check2-circle me-2"></i>Değişiklikleri Kaydet
                            </button>

                            <a asp-action="Index" class="btn btn-outline-secondary cancel-btn">
                                Vazgeç
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Preview and summary column -->
            <div class="col-xl-4">
                <!-- Preview card -->
                <div class="preview-card mb-4">
                    <div class="card-header-custom">
                        <div class="card-title-custom">Önizleme</div>
                        <p class="card-subtitle-custom">Görsel ve temel ürün görünümü</p>
                    </div>

                    <div class="card-body-custom">
                        <div class="preview-box">
                            @if (!string.IsNullOrWhiteSpace(Model?.ImageUrl))
                            {
                                <img src="@Model.ImageUrl" id="imagePreview" alt="Ürün Görseli" class="preview-image" />
                                <div id="imagePreviewPlaceholder" class="preview-placeholder d-none">
                                    <i class="bi bi-image"></i>
                                </div>
                            }
                            else
                            {
                                <div id="imagePreviewPlaceholder" class="preview-placeholder">
                                    <i class="bi bi-image"></i>
                                </div>
                                <img src="" id="imagePreview" alt="Ürün Görseli" class="preview-image d-none" />
                            }

                            <div class="preview-title" id="previewName">
                                @(string.IsNullOrWhiteSpace(Model?.Name) ? "Ürün adı burada görünecek" : Model.Name)
                            </div>

                            <p class="preview-text" id="previewDescription">
                                @(string.IsNullOrWhiteSpace(Model?.Description) ? "Ürün açıklaması burada görünecek." : Model.Description)
                            </p>
                        </div>
                    </div>
                </div>

                <!-- Summary card -->
                <div class="preview-card">
                    <div class="card-header-custom">
                        <div class="card-title-custom">Kayıt Özeti</div>
                        <p class="card-subtitle-custom">Mevcut ürün bilgileri</p>
                    </div>

                    <div class="card-body-custom">
                        <div class="info-list">
                            <div class="info-item">
                                <div class="info-icon"><i class="bi bi-calendar-check"></i></div>
                                <div>
                                    <div class="info-label">Oluşturulma Tarihi</div>
                                    <div class="info-value">@Model.CreatedDate.ToString("dd.MM.yyyy")</div>
                                </div>
                            </div>

                            <div class="info-item">
                                <div class="info-icon"><i class="bi bi-box-seam"></i></div>
                                <div>
                                    <div class="info-label">Mevcut Stok</div>
                                    <div class="info-value">@Model.StockQuantity adet</div>
                                </div>
                            </div>

                            <div class="info-item">
                                <div class="info-icon"><i class="bi bi-exclamation-triangle"></i></div>
                                <div>
                                    <div class="info-label">Kritik Seviye</div>
                                    <div class="info-value">@Model.CriticalStockLevel adet</div>
                                </div>
                            </div>

                            <div class="info-item">
                                <div class="info-icon"><i class="bi bi-cash-stack"></i></div>
                                <div>
                                    <div class="info-label">Birim Fiyat</div>
                                    <div class="info-value">@Model.UnitPrice.ToString("C")</div>
                                </div>
                            </div>

                            <div class="info-item">
                                <div class="info-icon"><i class="bi bi-check2-square"></i></div>
                                <div>
                                    <div class="info-label">Durum</div>
                                    <div class="info-value">@(Model.IsActive ? "Aktif" : "Pasif")</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        // =========================
        // PREVIEW ELEMENTS
        // =========================
        const nameInput = document.getElementById("Name");
        const descInput = document.getElementById("Description");
        const imageInput = document.getElementById("imageFile");
        const previewName = document.getElementById("previewName");
        const previewDescription = document.getElementById("previewDescription");
        const imagePreview = document.getElementById("imagePreview");
        const imagePreviewPlaceholder = document.getElementById("imagePreviewPlaceholder");

        // Update preview title on input
        if (nameInput) {
            nameInput.addEventListener("input", function () {
                previewName.textContent = this.value.trim() || "Ürün adı burada görünecek";
            });
        }

        // Update preview description on input
        if (descInput) {
            descInput.addEventListener("input", function () {
                previewDescription.textContent = this.value.trim() || "Ürün açıklaması burada görünecek.";
            });
        }

        // Update preview image on file selection
        if (imageInput) {
            imageInput.addEventListener("change", function (e) {
                const file = e.target.files[0];

                if (!file) {
                    return;
                }

                const reader = new FileReader();
                reader.onload = function (event) {
                    imagePreview.src = event.target.result;
                    imagePreview.classList.remove("d-none");

                    if (imagePreviewPlaceholder) {
                        imagePreviewPlaceholder.classList.add("d-none");
                    }
                };

                reader.readAsDataURL(file);
            });
        }
    </script>
}