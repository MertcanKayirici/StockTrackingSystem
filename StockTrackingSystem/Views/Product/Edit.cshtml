@model StockTrackingSystem.Models.Product
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewData["Title"] = "Ürün Düzenle";
    var categories = ViewBag.Categories as List<SelectListItem> ?? new List<SelectListItem>();
    var suppliers = ViewBag.Suppliers as List<SelectListItem> ?? new List<SelectListItem>();
}

<style>
    body {
        background: #f8fafc;
    }

    .edit-page-card, .edit-form-card {
        border: 0;
        border-radius: 24px;
        background: #ffffff;
        box-shadow: 0 10px 30px rgba(15, 23, 42, 0.06);
    }

    .edit-page-card {
        padding: 30px 32px;
        margin-bottom: 24px;
    }

    .edit-page-title {
        font-size: 2rem;
        font-weight: 800;
        color: #0f172a;
        margin-bottom: 6px;
    }

    .edit-page-subtitle {
        color: #64748b;
        font-size: 1.02rem;
        margin-bottom: 0;
    }

    .edit-form-card {
        overflow: hidden;
    }

    .edit-form-header {
        padding: 24px 28px 12px;
        border-bottom: 1px solid #f1f5f9;
    }

    .edit-form-title {
        font-size: 1.15rem;
        font-weight: 800;
        color: #0f172a;
        margin-bottom: 4px;
    }

    .edit-form-text {
        color: #64748b;
        margin-bottom: 0;
        font-size: 0.96rem;
    }

    .edit-form-body {
        padding: 28px;
    }

    .form-label {
        font-size: 0.96rem;
        font-weight: 700;
        color: #1e293b;
        margin-bottom: 10px;
    }

    .form-control, .form-select, textarea.form-control {
        min-height: 54px;
        border-radius: 16px;
        border: 1px solid #dbe2ea;
        padding-left: 16px;
        padding-right: 16px;
        background: #fff;
        font-size: 1rem;
        box-shadow: none;
        transition: all 0.2s ease;
    }

    textarea.form-control {
        min-height: 130px;
        padding-top: 14px;
        resize: vertical;
    }

        .form-control:focus, .form-select:focus, textarea.form-control:focus {
            border-color: #3b82f6;
            box-shadow: 0 0 0 0.22rem rgba(59, 130, 246, 0.12);
        }

    .alert-danger {
        border-radius: 16px;
        border: 0;
        background: #fef2f2;
        color: #b91c1c;
        padding: 14px 16px;
        margin-bottom: 20px;
    }

    .meta-card, .status-box, .image-box {
        border: 1px solid #e2e8f0;
        border-radius: 18px;
        background: #f8fafc;
        padding: 18px 20px;
    }

    .meta-label {
        font-size: 0.85rem;
        font-weight: 700;
        color: #64748b;
        margin-bottom: 8px;
        text-transform: uppercase;
        letter-spacing: 0.03em;
    }

    .meta-value {
        font-size: 1rem;
        font-weight: 700;
        color: #0f172a;
    }

    .status-box {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 14px;
    }

    .status-box-left h6, .image-box h6 {
        margin: 0 0 4px 0;
        font-weight: 700;
        color: #0f172a;
        font-size: 1rem;
    }

    .status-box-left p, .image-box p {
        margin: 0;
        color: #64748b;
        font-size: 0.9rem;
    }

    .modern-switch {
        position: relative;
        display: inline-block;
        width: 54px;
        height: 30px;
        margin: 0;
        flex-shrink: 0;
    }

        .modern-switch input {
            opacity: 0;
            width: 0;
            height: 0;
        }

        .modern-switch .slider {
            position: absolute;
            inset: 0;
            cursor: pointer;
            background: #e5e7eb;
            transition: .25s ease;
            border-radius: 999px;
            box-shadow: inset 0 0 0 1px rgba(15, 23, 42, 0.06);
        }

            .modern-switch .slider:before {
                content: "";
                position: absolute;
                height: 22px;
                width: 22px;
                left: 4px;
                top: 4px;
                background: white;
                transition: .25s ease;
                border-radius: 50%;
                box-shadow: 0 4px 10px rgba(15, 23, 42, 0.15);
            }

        .modern-switch input:checked + .slider {
            background: linear-gradient(135deg, #2563eb, #3b82f6);
        }

            .modern-switch input:checked + .slider:before {
                transform: translateX(24px);
            }

    .status-text {
        min-width: 56px;
        text-align: right;
        font-size: 0.92rem;
        font-weight: 800;
    }

    .status-active {
        color: #16a34a;
    }

    .status-passive {
        color: #ef4444;
    }

    .current-image-wrap {
        margin-top: 16px;
        display: flex;
        flex-wrap: wrap;
        gap: 16px;
        align-items: flex-start;
    }

    .current-image {
        width: 180px;
        height: 180px;
        object-fit: cover;
        border-radius: 18px;
        border: 1px solid #e2e8f0;
        background: #fff;
    }

    .image-preview-wrap {
        margin-top: 16px;
        display: none;
    }

    .image-preview {
        width: 180px;
        height: 180px;
        object-fit: cover;
        border-radius: 18px;
        border: 1px solid #e2e8f0;
        background: #fff;
    }

    .form-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-top: 28px;
    }

    .save-btn, .cancel-btn {
        min-height: 52px;
        border-radius: 16px;
        padding: 0 24px;
        font-weight: 700;
        font-size: 0.98rem;
        display: inline-flex;
        align-items: center;
        text-decoration: none;
    }
</style>

<div class="container py-4">
    <div class="edit-page-card">
        <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
            <div>
                <h1 class="edit-page-title">Ürün Düzenle</h1>
                <p class="edit-page-subtitle">Ürün bilgilerini, görselini ve stok ayarlarını güncelleyebilirsin.</p>
            </div>

            <a asp-action="Index" class="btn btn-outline-secondary cancel-btn">
                <i class="bi bi-arrow-left me-2"></i>Listeye Dön
            </a>
        </div>
    </div>

    <div class="edit-form-card">
        <div class="edit-form-header">
            <div class="edit-form-title">Ürün Düzenleme Formu</div>
            <p class="edit-form-text">Aşağıdaki alanları güncelleyerek ürün kaydını düzenleyebilirsin.</p>
        </div>

        <div class="edit-form-body">
            <form asp-action="Edit" method="post" enctype="multipart/form-data">
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="CreatedDate" />
                <input type="hidden" asp-for="ImageUrl" />

                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <div class="row g-4 mb-4">
                    <div class="col-md-6">
                        <div class="meta-card">
                            <div class="meta-label">Ürün ID</div>
                            <div class="meta-value">#@Model.Id</div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="meta-card">
                            <div class="meta-label">Oluşturulma Tarihi</div>
                            <div class="meta-value">@Model.CreatedDate.ToString("dd.MM.yyyy HH:mm")</div>
                        </div>
                    </div>
                </div>

                <div class="row g-4">
                    <div class="col-md-6">
                        <label asp-for="Name" class="form-label">Ürün Adı</label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="ProductCode" class="form-label">Ürün Kodu</label>
                        <input asp-for="ProductCode" class="form-control" />
                        <span asp-validation-for="ProductCode" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="CategoryId" class="form-label">Kategori</label>
                        <select asp-for="CategoryId" class="form-select">
                            <option value="">Kategori Seçiniz</option>
                            @foreach (var category in categories)
                            {
                                <option value="@category.Value" selected="@(Model.CategoryId.ToString() == category.Value)">
                                    @category.Text
                                </option>
                            }
                        </select>
                        <span asp-validation-for="CategoryId" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="SupplierId" class="form-label">Tedarikçi</label>
                        <select asp-for="SupplierId" class="form-select">
                            <option value="">Tedarikçi Seçiniz</option>
                            @foreach (var supplier in suppliers)
                            {
                                <option value="@supplier.Value" selected="@(Model.SupplierId.ToString() == supplier.Value)">
                                    @supplier.Text
                                </option>
                            }
                        </select>
                        <span asp-validation-for="SupplierId" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="col-12">
                        <label asp-for="Description" class="form-label">Açıklama</label>
                        <textarea asp-for="Description" class="form-control" rows="5"></textarea>
                        <span asp-validation-for="Description" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="col-md-3">
                        <label asp-for="UnitPrice" class="form-label">Birim Fiyat</label>
                        <input asp-for="UnitPrice" class="form-control" type="number" step="0.01" min="0" />
                        <span asp-validation-for="UnitPrice" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="col-md-3">
                        <label asp-for="StockQuantity" class="form-label">Stok Miktarı</label>
                        <input asp-for="StockQuantity" class="form-control" type="number" min="0" />
                        <span asp-validation-for="StockQuantity" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="col-md-3">
                        <label asp-for="CriticalStockLevel" class="form-label">Kritik Stok</label>
                        <input asp-for="CriticalStockLevel" class="form-control" type="number" min="0" />
                        <span asp-validation-for="CriticalStockLevel" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="col-md-3">
                        <label asp-for="UnitType" class="form-label">Birim Türü</label>
                        <select asp-for="UnitType" class="form-select">
                            <option value="Adet">Adet</option>
                            <option value="Kg">Kg</option>
                            <option value="Litre">Litre</option>
                            <option value="Paket">Paket</option>
                            <option value="Kutu">Kutu</option>
                        </select>
                        <span asp-validation-for="UnitType" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="col-12">
                        <label class="form-label">Ürün Görseli</label>
                        <div class="image-box">
                            <h6>Görsel Yönetimi</h6>
                            <p>Yeni görsel seçersen eski görsel klasörden silinir.</p>

                            <input type="file" name="imageFile" id="imageFile" class="form-control mt-3" accept=".jpg,.jpeg,.png,.webp" />

                            @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
                            {
                                <div class="current-image-wrap">
                                    <div>
                                        <img src="@Model.ImageUrl" alt="@Model.Name" class="current-image" />
                                    </div>

                                    <div class="form-check mt-2">
                                        <input class="form-check-input" type="checkbox" name="removeImage" value="true" id="removeImage" />
                                        <label class="form-check-label" for="removeImage">
                                            Mevcut görseli kaldır
                                        </label>
                                    </div>
                                </div>
                            }

                            <div class="image-preview-wrap" id="imagePreviewWrap">
                                <img id="imagePreview" class="image-preview" alt="Yeni önizleme" />
                            </div>
                        </div>
                    </div>

                    <div class="col-12">
                        <label class="form-label">Durum</label>

                        <div class="status-box">
                            <div class="status-box-left">
                                <h6>Ürün Durumu</h6>
                                <p>Bu ürünün aktif veya pasif olmasını buradan değiştirebilirsin.</p>
                            </div>

                            <div class="d-flex align-items-center gap-3">
                                <label class="modern-switch">
                                    <input asp-for="IsActive" id="isActiveSwitch" />
                                    <span class="slider"></span>
                                </label>

                                <span id="statusLabel" class="status-text @(Model.IsActive ? "status-active" : "status-passive")">
                                    @(Model.IsActive ? "Aktif" : "Pasif")
                                </span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn btn-warning save-btn">
                        <i class="bi bi-check2-circle me-2"></i>Güncelle
                    </button>

                    <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-primary cancel-btn">
                        <i class="bi bi-eye me-2"></i>Detaya Git
                    </a>

                    <a asp-action="Index" class="btn btn-outline-secondary cancel-btn">
                        <i class="bi bi-x-circle me-2"></i>Vazgeç
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        const isActiveSwitch = document.getElementById("isActiveSwitch");
        const statusLabel = document.getElementById("statusLabel");
        const imageFile = document.getElementById("imageFile");
        const imagePreview = document.getElementById("imagePreview");
        const imagePreviewWrap = document.getElementById("imagePreviewWrap");

        function updateStatusLabel() {
            if (!isActiveSwitch || !statusLabel) return;

            if (isActiveSwitch.checked) {
                statusLabel.textContent = "Aktif";
                statusLabel.classList.remove("status-passive");
                statusLabel.classList.add("status-active");
            } else {
                statusLabel.textContent = "Pasif";
                statusLabel.classList.remove("status-active");
                statusLabel.classList.add("status-passive");
            }
        }

        if (isActiveSwitch) {
            updateStatusLabel();
            isActiveSwitch.addEventListener("change", updateStatusLabel);
        }

        if (imageFile) {
            imageFile.addEventListener("change", function () {
                const file = this.files && this.files[0];
                if (!file) {
                    imagePreviewWrap.style.display = "none";
                    imagePreview.src = "";
                    return;
                }

                const reader = new FileReader();
                reader.onload = function (e) {
                    imagePreview.src = e.target.result;
                    imagePreviewWrap.style.display = "block";
                };
                reader.readAsDataURL(file);
            });
        }
    </script>
}