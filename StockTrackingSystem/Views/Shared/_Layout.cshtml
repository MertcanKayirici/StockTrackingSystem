<!DOCTYPE html>
<html lang="tr">
<head>
    <!-- Basic meta settings -->
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Page title -->
    <title>@ViewData["Title"] - StockTrackingSystem</title>

    <!-- External styles -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/StockTrackingSystem.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <style>
        /* =========================
                   GLOBAL SETTINGS
                ========================= */
        html {
            font-size: 14px;
        }

        body {
            background: linear-gradient(180deg, #f8fafc 0%, #f1f5f9 100%);
            color: #0f172a;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* =========================
                   NAVBAR
                ========================= */
        .app-navbar {
            background: rgba(255, 255, 255, 0.92);
            backdrop-filter: blur(12px);
            border-bottom: 1px solid rgba(226, 232, 240, 0.9);
            box-shadow: 0 10px 30px rgba(15, 23, 42, 0.05);
            padding-top: 0.9rem;
            padding-bottom: 0.9rem;
            position: sticky;
            top: 0;
            z-index: 1030;
        }

        .brand-wrap {
            display: flex;
            align-items: center;
            gap: 12px;
            text-decoration: none;
        }

        .brand-logo {
            width: 46px;
            height: 46px;
            border-radius: 16px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, #2563eb, #1d4ed8);
            color: #ffffff;
            font-size: 1.2rem;
            box-shadow: 0 10px 24px rgba(37, 99, 235, 0.25);
            flex-shrink: 0;
        }

        .brand-text {
            display: flex;
            flex-direction: column;
            line-height: 1.1;
        }

        .brand-title {
            font-size: 1rem;
            font-weight: 800;
            color: #0f172a;
            margin: 0;
        }

        .brand-subtitle {
            font-size: 0.78rem;
            color: #64748b;
            margin: 0;
        }

        .navbar-toggler {
            border: 0;
            border-radius: 14px;
            width: 46px;
            height: 46px;
            padding: 0;
            box-shadow: none !important;
            background: #f8fafc;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

            .navbar-toggler i {
                font-size: 1.3rem;
                color: #0f172a;
            }

        .nav-shell {
            gap: 10px;
        }

        .main-nav {
            gap: 8px;
        }

            .main-nav .nav-link {
                color: #334155 !important;
                font-weight: 700;
                border-radius: 14px;
                padding: 10px 16px !important;
                transition: all 0.2s ease;
                display: inline-flex;
                align-items: center;
                gap: 8px;
            }

                .main-nav .nav-link:hover {
                    background: #eff6ff;
                    color: #2563eb !important;
                }

        /* =========================
                   QUICK ACTIONS
                ========================= */
        .quick-actions {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .quick-btn {
            min-height: 42px;
            padding: 0 16px;
            border-radius: 14px;
            font-weight: 700;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            text-decoration: none;
            transition: all 0.2s ease;
        }

        .quick-btn-primary {
            background: linear-gradient(135deg, #2563eb, #1d4ed8);
            color: #ffffff;
            box-shadow: 0 10px 22px rgba(37, 99, 235, 0.22);
        }

            .quick-btn-primary:hover {
                color: #ffffff;
                transform: translateY(-1px);
            }

        .quick-btn-soft {
            background: #ffffff;
            color: #0f172a;
            border: 1px solid #e2e8f0;
        }

            .quick-btn-soft:hover {
                background: #f8fafc;
                color: #0f172a;
            }

        /* =========================
                   PAGE LAYOUT
                ========================= */
        .page-wrapper {
            flex: 1;
            padding-top: 28px;
            padding-bottom: 28px;
        }

        .page-container {
            max-width: 1400px;
        }

        /* =========================
                   FOOTER (FIRST BLOCK)
                ========================= */
        .app-footer {
            margin-top: auto;
            border-top: 1px solid #e2e8f0;
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(8px);
        }

        .footer-inner {
            min-height: 72px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 16px;
            flex-wrap: wrap;
            color: #64748b;
            font-size: 0.95rem;
        }

        /* =========================
                   RESPONSIVE NAVBAR
                ========================= */
        @@media (max-width: 991.98px) {
            .nav-shell {
                margin-top: 16px;
                padding: 16px;
                border: 1px solid #e2e8f0;
                border-radius: 20px;
                background: #ffffff;
                box-shadow: 0 12px 28px rgba(15, 23, 42, 0.05);
            }

            .main-nav {
                gap: 6px;
            }

                .main-nav .nav-link {
                    width: 100%;
                }

            .quick-actions {
                margin-top: 12px;
                flex-direction: column;
                align-items: stretch;
            }

            .quick-btn {
                justify-content: center;
            }
        }

        /* =========================
                   FOOTER (SECOND BLOCK)
                ========================= */
        .app-footer {
            margin-top: auto;
            background: rgba(255, 255, 255, 0.9);
            border-top: 1px solid #e2e8f0;
            backdrop-filter: blur(8px);
            padding-top: 20px;
            padding-bottom: 16px;
        }

        .footer-inner {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 16px;
            flex-wrap: wrap;
            padding-bottom: 14px;
        }

        .footer-left {
            display: flex;
            align-items: center;
        }

        .footer-brand {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .footer-logo {
            width: 40px;
            height: 40px;
            border-radius: 14px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, #2563eb, #1d4ed8);
            color: #ffffff;
            font-size: 1rem;
            box-shadow: 0 8px 18px rgba(37, 99, 235, 0.2);
        }

        .footer-brand-title {
            font-size: 0.95rem;
            font-weight: 800;
            color: #0f172a;
            line-height: 1.1;
        }

        .footer-brand-subtitle {
            font-size: 0.78rem;
            color: #64748b;
            line-height: 1.1;
        }

        .footer-right {
            display: flex;
            align-items: center;
            gap: 18px;
            flex-wrap: wrap;
        }

            .footer-right a {
                text-decoration: none;
                color: #64748b;
                font-weight: 600;
                transition: color 0.2s ease;
            }

                .footer-right a:hover {
                    color: #2563eb;
                }

        .footer-bottom {
            border-top: 1px solid #e2e8f0;
            padding-top: 12px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            flex-wrap: wrap;
            font-size: 0.88rem;
            color: #64748b;
        }

        /* =========================
                   MOBILE FOOTER
                ========================= */
        @@media (max-width: 768px) {
            .footer-inner, .footer-bottom {
                flex-direction: column;
                align-items: flex-start;
            }

            .footer-right {
                gap: 12px;
            }
        }
    </style>

