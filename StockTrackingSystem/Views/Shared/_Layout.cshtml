<body>
    <!-- =========================
         HEADER / NAVBAR
    ========================= -->
    <header>
        <nav class="navbar navbar-expand-lg app-navbar">
            <div class="container page-container">
                <a class="brand-wrap" asp-controller="Dashboard" asp-action="Index">
                    <span class="brand-logo">
                        <i class="bi bi-box-seam-fill"></i>
                    </span>
                    <span class="brand-text">
                        <span class="brand-title">StockTrackingSystem</span>
                        <span class="brand-subtitle">Inventory & Management Panel</span>
                    </span>
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar"
                        aria-controls="mainNavbar" aria-expanded="false" aria-label="Menüyü Aç/Kapat">
                    <i class="bi bi-list"></i>
                </button>

                <div class="collapse navbar-collapse justify-content-between nav-shell" id="mainNavbar">
                    <ul class="navbar-nav main-nav mb-3 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Dashboard" asp-action="Index">
                                <i class="bi bi-speedometer2"></i> Dashboard
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Category" asp-action="Index">
                                <i class="bi bi-grid-1x2-fill"></i> Kategoriler
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Product" asp-action="Index">
                                <i class="bi bi-box-seam"></i> Ürünler
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Supplier" asp-action="Index">
                                <i class="bi bi-buildings"></i> Tedarikçiler
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="StockMovement" asp-action="Index">
                                <i class="bi bi-arrow-left-right"></i> Stok Hareketleri
                            </a>
                        </li>
                    </ul>

                    <div class="quick-actions">
                        <a class="quick-btn quick-btn-soft" asp-controller="Product" asp-action="Create">
                            <i class="bi bi-plus-circle"></i> Ürün Ekle
                        </a>

                        <a class="quick-btn quick-btn-primary" asp-controller="StockMovement" asp-action="Create">
                            <i class="bi bi-plus-lg"></i> Hareket Ekle
                        </a>
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <!-- =========================
         PAGE CONTENT
    ========================= -->
    <div class="page-wrapper">
        <main role="main" class="container page-container">
            @RenderBody()
        </main>
    </div>

    <!-- =========================
         FOOTER
    ========================= -->
    <footer class="app-footer">
        <div class="container page-container">
            <div class="footer-inner">
                <div class="footer-left">
                    <div class="footer-brand">
                        <span class="footer-logo">
                            <i class="bi bi-box-seam-fill"></i>
                        </span>
                        <div>
                            <div class="footer-brand-title">StockTrackingSystem</div>
                            <div class="footer-brand-subtitle">Inventory Management Panel</div>
                        </div>
                    </div>
                </div>

                <div class="footer-right">
                    <a asp-controller="Dashboard" asp-action="Index">Dashboard</a>
                    <a asp-controller="Product" asp-action="Index">Ürünler</a>
                    <a asp-controller="StockMovement" asp-action="Index">Hareketler</a>
                </div>
            </div>

            <div class="footer-bottom">
                <span>© 2026 StockTrackingSystem</span>
                <span>Developed by Mertcan</span>
            </div>
        </div>
    </footer>

    <!-- =========================
         SCRIPTS
    ========================= -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>