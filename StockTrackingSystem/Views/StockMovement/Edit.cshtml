@model StockTrackingSystem.Models.StockMovement
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewData["Title"] = "Stok Hareketi Düzenle";
    var products = ViewBag.Products as List<SelectListItem> ?? new List<SelectListItem>();
}

<style>
    body {
        background: #f8fafc;
    }

    .page-card, .form-card {
        border: 0;
        border-radius: 24px;
        background: #ffffff;
        box-shadow: 0 10px 30px rgba(15, 23, 42, 0.06);
    }

    .page-card {
        padding: 30px 32px;
        margin-bottom: 24px;
    }

    .page-title {
        font-size: 2rem;
        font-weight: 800;
        color: #0f172a;
        margin-bottom: 6px;
    }

    .page-subtitle {
        color: #64748b;
        font-size: 1.02rem;
        margin-bottom: 0;
    }

    .form-card {
        overflow: hidden;
    }

    .form-header {
        padding: 24px 28px 12px 28px;
        border-bottom: 1px solid #f1f5f9;
    }

    .form-title {
        font-size: 1.15rem;
        font-weight: 800;
        color: #0f172a;
        margin-bottom: 4px;
    }

    .form-text {
        color: #64748b;
        margin-bottom: 0;
        font-size: 0.96rem;
    }

    .form-body {
        padding: 28px;
    }

    .form-label {
        font-size: 0.96rem;
        font-weight: 700;
        color: #1e293b;
        margin-bottom: 10px;
    }

    .form-control, .form-select, textarea.form-control {
        min-height: 54px;
        border-radius: 16px;
        border: 1px solid #dbe2ea;
        padding-left: 16px;
        padding-right: 16px;
        background: #fff;
        font-size: 1rem;
        box-shadow: none;
        transition: all 0.2s ease;
    }

    textarea.form-control {
        min-height: 120px;
        padding-top: 14px;
        resize: vertical;
    }

        .form-control:focus, .form-select:focus, textarea.form-control:focus {
            border-color: #3b82f6;
            box-shadow: 0 0 0 0.22rem rgba(59, 130, 246, 0.12);
        }

    .alert-danger {
        border-radius: 16px;
        border: 0;
        background: #fef2f2;
        color: #b91c1c;
        padding: 14px 16px;
        margin-bottom: 20px;
    }

    .meta-card {
        border: 1px solid #eef2f7;
        background: #f8fafc;
        border-radius: 18px;
        padding: 18px 20px;
        height: 100%;
    }

    .meta-label {
        font-size: 0.85rem;
        font-weight: 700;
        color: #64748b;
        margin-bottom: 8px;
        text-transform: uppercase;
        letter-spacing: 0.03em;
    }

    .meta-value {
        font-size: 1rem;
        font-weight: 700;
        color: #0f172a;
    }

    .info-box {
        border: 1px solid #e2e8f0;
        border-radius: 18px;
        padding: 16px 18px;
        background: #f8fafc;
    }

    .form-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-top: 28px;
    }

    .save-btn, .cancel-btn {
        min-height: 52px;
        border-radius: 16px;
        padding: 0 24px;
        font-weight: 700;
        font-size: 0.98rem;
        display: inline-flex;
        align-items: center;
        text-decoration: none;
    }
</style>

<div class="container py-4">
    <div class="page-card">
        <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
            <div>
                <h1 class="page-title">Stok Hareketi Düzenle</h1>
                <p class="page-subtitle">Mevcut hareketi güncelleyerek stok etkisini yeniden hesaplayabilirsin.</p>
            </div>

            <a asp-action="Index" class="btn btn-outline-secondary cancel-btn">
                <i class="bi bi-arrow-left me-2"></i>Listeye Dön
            </a>
        </div>
    </div>

    <div class="form-card">
        <div class="form-header">
            <div class="form-title">Hareket Düzenleme Formu</div>
            <p class="form-text">Bu kaydı güncellediğinde ürün stoğu otomatik yeniden hesaplanır.</p>
        </div>

        <div class="form-body">
            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="CreatedDate" />

                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <div class="row g-4 mb-4">
                    <div class="col-md-6">
                        <div class="meta-card">
                            <div class="meta-label">Hareket ID</div>
                            <div class="meta-value">#@Model.Id</div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="meta-card">
                            <div class="meta-label">Kayıt Tarihi</div>
                            <div class="meta-value">@Model.CreatedDate.ToString("dd.MM.yyyy HH:mm")</div>
                        </div>
                    </div>
                </div>

                <div class="row g-4">
                    <div class="col-md-6">
                        <label asp-for="ProductId" class="form-label">Ürün</label>
                        <select asp-for="ProductId" class="form-select">
                            <option value="">Ürün Seçiniz</option>
                            @foreach (var product in products)
                            {
                                <option value="@product.Value" selected="@(Model.ProductId.ToString() == product.Value)">
                                    @product.Text
                                </option>
                            }
                        </select>
                        <span asp-validation-for="ProductId" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="MovementType" class="form-label">Hareket Tipi</label>
                        <select asp-for="MovementType" class="form-select">
                            <option value="In" selected="@(Model.MovementType == "In")">Giriş (In)</option>
                            <option value="Out" selected="@(Model.MovementType == "Out")">Çıkış (Out)</option>
                        </select>
                        <span asp-validation-for="MovementType" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="Quantity" class="form-label">Miktar</label>
                        <input asp-for="Quantity" class="form-control" type="number" min="1" />
                        <span asp-validation-for="Quantity" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="UnitPrice" class="form-label">Birim Fiyat</label>
                        <input asp-for="UnitPrice" class="form-control" type="number" min="0" step="0.01" />
                        <span asp-validation-for="UnitPrice" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="ReferenceCode" class="form-label">Referans Kodu</label>
                        <input asp-for="ReferenceCode" class="form-control" />
                        <span asp-validation-for="ReferenceCode" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="MovementDate" class="form-label">Hareket Tarihi</label>
                        <input asp-for="MovementDate" class="form-control" type="datetime-local"
                               value="@Model.MovementDate.ToString("yyyy-MM-ddTHH:mm")" />
                        <span asp-validation-for="MovementDate" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="col-md-6">
                        <div class="info-box h-100 d-flex flex-column justify-content-center">
                            <strong class="mb-2">Düzenleme Mantığı</strong>
                            <span class="text-muted">Eski hareket geri alınır, yeni değerler yeniden uygulanır.</span>
                        </div>
                    </div>

                    <div class="col-12">
                        <label asp-for="Description" class="form-label">Açıklama</label>
                        <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                        <span asp-validation-for="Description" class="text-danger small mt-1 d-block"></span>
                    </div>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn btn-warning save-btn">
                        <i class="bi bi-check2-circle me-2"></i>Güncelle
                    </button>

                    <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-primary cancel-btn">
                        <i class="bi bi-eye me-2"></i>Detaya Git
                    </a>

                    <a asp-action="Index" class="btn btn-outline-secondary cancel-btn">
                        <i class="bi bi-x-circle me-2"></i>Vazgeç
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}