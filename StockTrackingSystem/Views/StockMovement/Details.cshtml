@model StockTrackingSystem.Models.StockMovement

@{
    // Page title
    ViewData["Title"] = "Hareket Detayı";
}

<style>
    /* =========================
           PAGE BACKGROUND
        ========================= */
    body {
        background: #f8fafc;
    }

    /* =========================
           MAIN CARDS
        ========================= */
    .page-card, .details-card, .stat-card {
        border: 0;
        border-radius: 24px;
        background: #ffffff;
        box-shadow: 0 10px 30px rgba(15, 23, 42, 0.06);
    }

    .page-card {
        padding: 30px 32px;
        margin-bottom: 24px;
    }

    /* =========================
           PAGE HEADER
        ========================= */
    .page-title {
        font-size: 2rem;
        font-weight: 800;
        color: #0f172a;
        margin-bottom: 6px;
    }

    .page-subtitle {
        color: #64748b;
        font-size: 1.02rem;
        margin-bottom: 0;
    }

    /* =========================
           STAT CARDS
        ========================= */
    .stat-card {
        padding: 22px 24px;
        display: flex;
        align-items: center;
        gap: 16px;
        height: 100%;
    }

    .stat-icon {
        width: 58px;
        height: 58px;
        border-radius: 18px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 1.35rem;
        background: rgba(37, 99, 235, 0.10);
        color: #2563eb;
    }

    .stat-label {
        color: #64748b;
        font-size: 0.92rem;
        font-weight: 600;
        margin-bottom: 6px;
    }

    .stat-value {
        font-size: 1.4rem;
        font-weight: 800;
        color: #0f172a;
    }

    /* =========================
           DETAILS CARD
        ========================= */
    .details-card {
        overflow: hidden;
    }

    .details-header {
        padding: 24px 28px 12px;
        border-bottom: 1px solid #f1f5f9;
    }

    .details-title {
        font-size: 1.15rem;
        font-weight: 800;
        color: #0f172a;
        margin-bottom: 4px;
    }

    .details-body {
        padding: 28px;
    }

    /* =========================
           DETAIL ITEMS
        ========================= */
    .detail-item {
        padding: 18px 20px;
        border: 1px solid #eef2f7;
        border-radius: 18px;
        background: #f8fafc;
        height: 100%;
    }

    .detail-label {
        font-size: 0.88rem;
        font-weight: 700;
        color: #64748b;
        margin-bottom: 8px;
        text-transform: uppercase;
        letter-spacing: 0.03em;
    }

    .detail-value {
        font-size: 1.02rem;
        font-weight: 700;
        color: #0f172a;
    }

    /* =========================
           PRODUCT IMAGE
        ========================= */
    .product-image {
        width: 220px;
        height: 220px;
        object-fit: cover;
        border-radius: 20px;
        border: 1px solid #e2e8f0;
        background: #fff;
    }

    /* =========================
           MOVEMENT BADGE
        ========================= */
    .movement-badge {
        display: inline-flex;
        align-items: center;
        border-radius: 999px;
        padding: 8px 14px;
        font-size: 0.9rem;
        font-weight: 800;
    }

    .movement-in {
        background: rgba(22, 163, 74, 0.10);
        color: #16a34a;
    }

    .movement-out {
        background: rgba(239, 68, 68, 0.10);
        color: #ef4444;
    }

    /* =========================
           ACTION BUTTONS
        ========================= */
    .action-buttons {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-top: 28px;
    }

    .action-btn-main, .action-btn-secondary {
        min-height: 52px;
        border-radius: 16px;
        padding: 0 24px;
        font-weight: 700;
        font-size: 0.98rem;
        display: inline-flex;
        align-items: center;
        text-decoration: none;
    }
</style>

<div class="container py-4">
    <!-- =========================
         PAGE HEADER
    ========================= -->
    <div class="page-card">
        <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
            <div>
                <h1 class="page-title">Hareket Detayı</h1>
                <p class="page-subtitle">Stok hareketine ait detayları görüntüleyebilirsin.</p>
            </div>

            <a asp-action="Index" class="btn btn-outline-secondary action-btn-secondary">
                <i class="bi bi-arrow-left me-2"></i>Listeye Dön
            </a>
        </div>
    </div>

    <!-- =========================
         STATISTICS
    ========================= -->
    <div class="row g-4 mb-4">
        <div class="col-md-4">
            <div class="stat-card">
                <div class="stat-icon"><i class="bi bi-arrow-left-right"></i></div>
                <div>
                    <div class="stat-label">Hareket Tipi</div>
                    <div class="stat-value">@(Model.MovementType == "In" ? "Giriş" : "Çıkış")</div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="stat-card">
                <div class="stat-icon"><i class="bi bi-123"></i></div>
                <div>
                    <div class="stat-label">Miktar</div>
                    <div class="stat-value">@Model.Quantity</div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="stat-card">
                <div class="stat-icon"><i class="bi bi-calendar2-check"></i></div>
                <div>
                    <div class="stat-label">Tarih</div>
                    <div class="stat-value" style="font-size:1.15rem;">@Model.MovementDate.ToString("dd.MM.yyyy HH:mm")</div>
                </div>
            </div>
        </div>
    </div>

    <!-- =========================
         MOVEMENT DETAILS
    ========================= -->
    <div class="details-card">
        <div class="details-header">
            <div class="details-title">Hareket Bilgileri</div>
        </div>

        <div class="details-body">
            <div class="row g-4">
                <!-- Product image -->
                <div class="col-lg-4">
                    <div class="detail-item text-center">
                        @if (!string.IsNullOrWhiteSpace(Model.Product?.ImageUrl))
                        {
                            <img src="@Model.Product.ImageUrl" alt="@Model.Product.Name" class="product-image" />
                        }
                        else
                        {
                            <div class="d-flex align-items-center justify-content-center product-image">
                                <span class="text-muted">Görsel yok</span>
                            </div>
                        }
                    </div>
                </div>

                <!-- Main detail fields -->
                <div class="col-lg-8">
                    <div class="row g-4">
                        <div class="col-md-6">
                            <div class="detail-item">
                                <div class="detail-label">Ürün</div>
                                <div class="detail-value">@Model.Product?.Name</div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="detail-item">
                                <div class="detail-label">Kategori</div>
                                <div class="detail-value">@Model.Product?.Category?.Name</div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="detail-item">
                                <div class="detail-label">Hareket Tipi</div>
                                <div class="detail-value">
                                    <span class="movement-badge @(Model.MovementType == "In" ? "movement-in" : "movement-out")">
                                        @(Model.MovementType == "In" ? "Giriş" : "Çıkış")
                                    </span>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="detail-item">
                                <div class="detail-label">Birim Fiyat</div>
                                <div class="detail-value">
                                    @(Model.UnitPrice.HasValue? Model.UnitPrice.Value.ToString("C") : "-")
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="detail-item">
                                <div class="detail-label">Referans Kodu</div>
                                <div class="detail-value">@(string.IsNullOrWhiteSpace(Model.ReferenceCode) ? "-" : Model.ReferenceCode)</div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="detail-item">
                                <div class="detail-label">Kayıt Tarihi</div>
                                <div class="detail-value">@Model.CreatedDate.ToString("dd.MM.yyyy HH:mm")</div>
                            </div>
                        </div>

                        <div class="col-12">
                            <div class="detail-item">
                                <div class="detail-label">Açıklama</div>
                                <div class="detail-value">@(string.IsNullOrWhiteSpace(Model.Description) ? "-" : Model.Description)</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Action buttons -->
            <div class="action-buttons">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning action-btn-main">
                    <i class="bi bi-pencil-square me-2"></i>Düzenle
                </a>

                <a asp-action="Index" class="btn btn-outline-secondary action-btn-secondary">
                    <i class="bi bi-arrow-left me-2"></i>Geri Dön
                </a>
            </div>
        </div>
    </div>
</div>