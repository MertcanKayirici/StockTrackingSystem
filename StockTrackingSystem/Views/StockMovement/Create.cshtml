@model StockTrackingSystem.Models.StockMovement
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    // Page title
    ViewData["Title"] = "Stok Hareketi Ekle";

    // Product dropdown data
    var products = ViewBag.Products as List<SelectListItem> ?? new List<SelectListItem>();
}

<style>
    /* =========================
           PAGE BACKGROUND
        ========================= */
    body {
        background: #f8fafc;
    }

    /* =========================
           MAIN CARDS
        ========================= */
    .page-card, .form-card {
        border: 0;
        border-radius: 24px;
        background: #ffffff;
        box-shadow: 0 10px 30px rgba(15, 23, 42, 0.06);
    }

    .page-card {
        padding: 30px 32px;
        margin-bottom: 24px;
    }

    /* =========================
           PAGE HEADER
        ========================= */
    .page-title {
        font-size: 2rem;
        font-weight: 800;
        color: #0f172a;
        margin-bottom: 6px;
    }

    .page-subtitle {
        color: #64748b;
        font-size: 1.02rem;
        margin-bottom: 0;
    }

    /* =========================
           FORM CARD
        ========================= */
    .form-card {
        overflow: hidden;
    }

    .form-header {
        padding: 24px 28px 12px 28px;
        border-bottom: 1px solid #f1f5f9;
    }

    .form-title {
        font-size: 1.15rem;
        font-weight: 800;
        color: #0f172a;
        margin-bottom: 4px;
    }

    .form-text {
        color: #64748b;
        margin-bottom: 0;
        font-size: 0.96rem;
    }

    .form-body {
        padding: 28px;
    }

    /* =========================
           FORM ELEMENTS
        ========================= */
    .form-label {
        font-size: 0.96rem;
        font-weight: 700;
        color: #1e293b;
        margin-bottom: 10px;
    }

    .form-control, .form-select, textarea.form-control {
        min-height: 54px;
        border-radius: 16px;
        border: 1px solid #dbe2ea;
        padding-left: 16px;
        padding-right: 16px;
        background: #fff;
        font-size: 1rem;
        box-shadow: none;
        transition: all 0.2s ease;
    }

    textarea.form-control {
        min-height: 120px;
        padding-top: 14px;
        resize: vertical;
    }

        .form-control:focus, .form-select:focus, textarea.form-control:focus {
            border-color: #3b82f6;
            box-shadow: 0 0 0 0.22rem rgba(59, 130, 246, 0.12);
        }

    .form-hint {
        color: #64748b;
        font-size: 0.88rem;
        margin-top: 8px;
    }

    /* =========================
           VALIDATION ALERT
        ========================= */
    .alert-danger {
        border-radius: 16px;
        border: 0;
        background: #fef2f2;
        color: #b91c1c;
        padding: 14px 16px;
        margin-bottom: 20px;
    }

    /* =========================
           MOVEMENT / PRODUCT INFO CARDS
        ========================= */
    .movement-type-card {
        border: 1px solid #e2e8f0;
        border-radius: 18px;
        background: #f8fafc;
        padding: 16px 18px;
    }

    .product-stock-info-card {
        border: 1px solid #dbeafe;
        border-radius: 20px;
        background: linear-gradient(180deg, #f8fbff 0%, #eef6ff 100%);
        padding: 18px;
    }

    .stock-info-box {
        border: 1px solid #e2e8f0;
        border-radius: 16px;
        background: #ffffff;
        padding: 16px;
        height: 100%;
    }

    .stock-info-label {
        font-size: 0.82rem;
        font-weight: 700;
        color: #64748b;
        text-transform: uppercase;
        letter-spacing: 0.03em;
        margin-bottom: 8px;
    }

    .stock-info-value {
        font-size: 1rem;
        font-weight: 800;
        color: #0f172a;
        word-break: break-word;
    }

    /* =========================
           ACTION BUTTONS
        ========================= */
    .form-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-top: 28px;
    }

    .save-btn, .cancel-btn {
        min-height: 52px;
        border-radius: 16px;
        padding: 0 24px;
        font-weight: 700;
        font-size: 0.98rem;
        display: inline-flex;
        align-items: center;
        text-decoration: none;
    }
</style>

<div class="container py-4">
    <!-- =========================
         PAGE HEADER
    ========================= -->
    <div class="page-card">
        <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
            <div>
                <h1 class="page-title">Stok Hareketi Ekle</h1>
                <p class="page-subtitle">Ürün için giriş veya çıkış hareketi oluşturarak stok miktarını güncelleyebilirsin.</p>
            </div>

            <a asp-action="Index" class="btn btn-outline-secondary cancel-btn">
                <i class="bi bi-arrow-left me-2"></i>Listeye Dön
            </a>
        </div>
    </div>

    <!-- =========================
         FORM CARD
    ========================= -->
    <div class="form-card">
        <div class="form-header">
            <div class="form-title">Hareket Bilgileri</div>
            <p class="form-text">Ürün, hareket tipi, miktar ve açıklama bilgilerini doldur.</p>
        </div>

        <div class="form-body">
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <div class="row g-4">
                    <!-- Product selection -->
                    <div class="col-md-6">
                        <label asp-for="ProductId" class="form-label">Ürün</label>
                        <select asp-for="ProductId" class="form-select" id="ProductId">
                            <option value="">Ürün Seçiniz</option>
                            @foreach (var product in products)
                            {
                                <option value="@product.Value">@product.Text</option>
                            }
                        </select>
                        <span asp-validation-for="ProductId" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <!-- Movement type -->
                    <div class="col-md-6">
                        <label asp-for="MovementType" class="form-label">Hareket Tipi</label>
                        <select asp-for="MovementType" class="form-select">
                            <option value="In">Giriş (In)</option>
                            <option value="Out">Çıkış (Out)</option>
                        </select>
                        <span asp-validation-for="MovementType" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <!-- Product stock info -->
                    <div class="col-12">
                        <div class="product-stock-info-card" id="productStockInfoCard" style="display:none;">
                            <div class="row g-3">
                                <div class="col-md-3">
                                    <div class="stock-info-box">
                                        <div class="stock-info-label">Ürün</div>
                                        <div class="stock-info-value" id="infoProductName">-</div>
                                    </div>
                                </div>

                                <div class="col-md-2">
                                    <div class="stock-info-box">
                                        <div class="stock-info-label">Kategori</div>
                                        <div class="stock-info-value" id="infoCategoryName">-</div>
                                    </div>
                                </div>

                                <div class="col-md-2">
                                    <div class="stock-info-box">
                                        <div class="stock-info-label">Mevcut Stok</div>
                                        <div class="stock-info-value text-primary" id="infoCurrentStock">0</div>
                                    </div>
                                </div>

                                <div class="col-md-2">
                                    <div class="stock-info-box">
                                        <div class="stock-info-label">Kritik Stok</div>
                                        <div class="stock-info-value text-danger" id="infoCriticalStock">0</div>
                                    </div>
                                </div>

                                <div class="col-md-3">
                                    <div class="stock-info-box">
                                        <div class="stock-info-label">Birim / Fiyat</div>
                                        <div class="stock-info-value" id="infoUnitTypePrice">-</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Quantity -->
                    <div class="col-md-4">
                        <label asp-for="Quantity" class="form-label">Miktar</label>
                        <input asp-for="Quantity" class="form-control" type="number" min="1" />
                        <span asp-validation-for="Quantity" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <!-- Unit price -->
                    <div class="col-md-4">
                        <label asp-for="UnitPrice" class="form-label">Birim Fiyat</label>
                        <input asp-for="UnitPrice" class="form-control" type="number" min="0" step="0.01" />
                        <span asp-validation-for="UnitPrice" class="text-danger small mt-1 d-block"></span>
                        <div class="form-hint">Girersen ürünün birim fiyatı da güncellenir.</div>
                    </div>

                    <!-- Reference code -->
                    <div class="col-md-4">
                        <label asp-for="ReferenceCode" class="form-label">Referans Kodu</label>
                        <input asp-for="ReferenceCode" class="form-control" placeholder="Örn: REF-1001" />
                        <span asp-validation-for="ReferenceCode" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <!-- Movement date -->
                    <div class="col-md-6">
                        <label asp-for="MovementDate" class="form-label">Hareket Tarihi</label>
                        <input asp-for="MovementDate" class="form-control" type="datetime-local"
                               value="@Model.MovementDate.ToString("yyyy-MM-ddTHH:mm")" />
                        <span asp-validation-for="MovementDate" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <!-- Movement logic info -->
                    <div class="col-md-6">
                        <div class="movement-type-card h-100 d-flex flex-column justify-content-center">
                            <strong class="mb-2">Hareket Mantığı</strong>
                            <span class="text-muted">Giriş seçilirse stok artar, çıkış seçilirse stok azalır.</span>
                        </div>
                    </div>

                    <!-- Description -->
                    <div class="col-12">
                        <label asp-for="Description" class="form-label">Açıklama</label>
                        <textarea asp-for="Description" class="form-control" rows="4" placeholder="Hareketle ilgili kısa açıklama giriniz..."></textarea>
                        <span asp-validation-for="Description" class="text-danger small mt-1 d-block"></span>
                    </div>
                </div>

                <!-- Form actions -->
                <div class="form-actions">
                    <button type="submit" class="btn btn-primary save-btn">
                        <i class="bi bi-check2-circle me-2"></i>Kaydet
                    </button>

                    <a asp-action="Index" class="btn btn-outline-secondary cancel-btn">
                        <i class="bi bi-x-circle me-2"></i>Vazgeç
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        // =========================
        // FORM ELEMENTS
        // =========================
        const productSelect = document.getElementById("ProductId");
        const productStockInfoCard = document.getElementById("productStockInfoCard");

        // Load selected product stock information
        async function loadProductStockInfo(productId) {
            if (!productId) {
                productStockInfoCard.style.display = "none";
                return;
            }

            try {
                const response = await fetch(`/StockMovement/GetProductStockInfo?productId=${productId}`);
                const result = await response.json();

                if (!result.success) {
                    productStockInfoCard.style.display = "none";
                    return;
                }

                document.getElementById("infoProductName").textContent = result.name;
                document.getElementById("infoCategoryName").textContent = result.categoryName;
                document.getElementById("infoCurrentStock").textContent = result.currentStock;
                document.getElementById("infoCriticalStock").textContent = result.criticalStock;
                document.getElementById("infoUnitTypePrice").textContent =
                    `${result.unitType} / ${result.unitPrice.toLocaleString('tr-TR', { style: 'currency', currency: 'TRY' })}`;

                productStockInfoCard.style.display = "block";
            } catch (error) {
                productStockInfoCard.style.display = "none";
            }
        }

        // Handle product change event
        if (productSelect) {
            productSelect.addEventListener("change", function () {
                loadProductStockInfo(this.value);
            });

            if (productSelect.value) {
                loadProductStockInfo(productSelect.value);
            }
        }
    </script>
}