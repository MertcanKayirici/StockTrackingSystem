@using StockTrackingSystem.Models

@{
    // Set page title
    ViewData["Title"] = "Dashboard";

    // Dashboard summary statistics
    int totalProducts = ViewBag.TotalProducts ?? 0;
    int totalCategories = ViewBag.TotalCategories ?? 0;
    int totalSuppliers = ViewBag.TotalSuppliers ?? 0;
    int totalMovements = ViewBag.TotalMovements ?? 0;
    int activeProducts = ViewBag.ActiveProducts ?? 0;
    int passiveProducts = ViewBag.PassiveProducts ?? 0;
    int criticalStockCount = ViewBag.CriticalStockCount ?? 0;
    int outOfStockCount = ViewBag.OutOfStockCount ?? 0;
    decimal totalStockValue = ViewBag.TotalStockValue ?? 0m;

    // Recent data collections displayed on the dashboard
    var latestAuditLogs = ViewBag.LatestAuditLogs as List<AuditLog> ?? new List<AuditLog>();
    var latestProducts = ViewBag.LatestProducts as List<Product> ?? new List<Product>();
    var latestMovements = ViewBag.LatestMovements as List<StockMovement> ?? new List<StockMovement>();
    var lowStockProducts = ViewBag.LowStockProducts as List<Product> ?? new List<Product>();

    // Chart datasets passed from the controller
    var categoryLabels = ViewBag.CategoryLabels as string ?? "[]";
    var categoryCounts = ViewBag.CategoryCounts as string ?? "[]";
    var movementLabels = ViewBag.MovementLabels as string ?? "[]";
    var movementCounts = ViewBag.MovementCounts as string ?? "[]";
    var dailyMovementLabels = ViewBag.DailyMovementLabels as string ?? "[]";
    var dailyMovementCounts = ViewBag.DailyMovementCounts as string ?? "[]";
    var monthlyMovementLabels = ViewBag.MonthlyMovementLabels as string ?? "[]";
    var monthlyMovementCounts = ViewBag.MonthlyMovementCounts as string ?? "[]";
    var yearlyMovementLabels = ViewBag.YearlyMovementLabels as string ?? "[]";
    var yearlyMovementCounts = ViewBag.YearlyMovementCounts as string ?? "[]";
}

<style>
    /* Page background */
    body {
        background: #f8fafc;
    }

    /* Shared card styles */
    .hero-card,
    .stats-card,
    .panel-card {
        border: 0;
        border-radius: 26px;
        background: #ffffff;
        box-shadow: 0 10px 30px rgba(15, 23, 42, 0.06);
    }

    /* Hero section container */
    .hero-card {
        padding: 34px;
        margin-bottom: 24px;
        position: relative;
        overflow: hidden;
    }

        /* Decorative background circle for hero section */
        .hero-card::after {
            content: "";
            position: absolute;
            right: -80px;
            top: -80px;
            width: 220px;
            height: 220px;
            border-radius: 50%;
            background: rgba(37, 99, 235, 0.08);
        }

    /* Hero content layer above decoration */
    .hero-content {
        position: relative;
        z-index: 2;
    }

    /* Hero text spacing */
    .hero-text {
        margin-bottom: 22px;
    }

    /* Main dashboard title */
    .hero-title {
        font-size: 2.4rem;
        font-weight: 800;
        color: #0f172a;
        margin-bottom: 8px;
    }

    /* Dashboard subtitle text */
    .hero-subtitle {
        color: #64748b;
        font-size: 1.02rem;
        max-width: 760px;
        margin-bottom: 0;
    }

    /* Hero action buttons wrapper */
    .hero-actions {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        align-items: center;
    }

    /* Shared hero button style */
    .hero-btn {
        min-height: 50px;
        border-radius: 16px;
        padding: 0 22px;
        font-weight: 700;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    /* Statistics card styling */
    .stats-card {
        position: relative;
        overflow: hidden;
        padding: 22px;
        height: 100%;
        transition: all 0.22s ease;
    }

        /* Hover effect for statistic cards */
        .stats-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 16px 36px rgba(15, 23, 42, 0.08);
        }

        /* Decorative circle for statistic cards */
        .stats-card::after {
            content: "";
            position: absolute;
            right: -18px;
            top: -18px;
            width: 90px;
            height: 90px;
            border-radius: 50%;
            opacity: 0.08;
        }

    /* Card accent colors */
    .card-blue::after {
        background: #2563eb;
    }

    .card-purple::after {
        background: #8b5cf6;
    }

    .card-teal::after {
        background: #14b8a6;
    }

    .card-red::after {
        background: #ef4444;
    }

    .card-orange::after {
        background: #f59e0b;
    }

    .card-slate::after {
        background: #0f172a;
    }

    /* Statistic card inner layout */
    .stats-wrap {
        display: flex;
        align-items: center;
        gap: 16px;
    }

    /* Statistic icon container */
    .stats-icon {
        width: 56px;
        height: 56px;
        border-radius: 18px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 1.25rem;
        flex-shrink: 0;
    }

    /* Icon color themes */
    .card-blue .stats-icon {
        background: rgba(37, 99, 235, 0.10);
        color: #2563eb;
    }

    .card-purple .stats-icon {
        background: rgba(139, 92, 246, 0.10);
        color: #8b5cf6;
    }

    .card-teal .stats-icon {
        background: rgba(20, 184, 166, 0.10);
        color: #14b8a6;
    }

    .card-red .stats-icon {
        background: rgba(239, 68, 68, 0.10);
        color: #ef4444;
    }

    .card-orange .stats-icon {
        background: rgba(245, 158, 11, 0.10);
        color: #f59e0b;
    }

    .card-slate .stats-icon {
        background: rgba(15, 23, 42, 0.08);
        color: #0f172a;
    }

    /* Statistic label text */
    .stats-label {
        color: #64748b;
        font-size: 0.92rem;
        font-weight: 600;
        margin-bottom: 6px;
    }

    /* Statistic value text */
    .stats-value {
        font-size: 1.9rem;
        font-weight: 800;
        line-height: 1;
        color: #0f172a;
    }

    /* Shared panel card layout */
    .panel-card {
        overflow: hidden;
        height: 100%;
        display: flex;
        flex-direction: column;
        position: relative;
    }

    /* Panel header area */
    .panel-header {
        padding: 24px 28px 14px 28px;
        border-bottom: 1px solid #f1f5f9;
    }

    /* Panel main title */
    .panel-title {
        font-size: 1.12rem;
        font-weight: 800;
        color: #0f172a;
        margin-bottom: 4px;
    }

    /* Panel subtitle */
    .panel-subtitle {
        color: #64748b;
        font-size: 0.93rem;
        margin-bottom: 0;
    }

    /* Panel content area */
    .panel-body {
        padding: 24px 28px 28px 28px;
        flex: 1;
        min-height: 0;
    }

    /* Vertical list container */
    .mini-list {
        display: flex;
        flex-direction: column;
        gap: 14px;
    }

    /* Individual list item card */
    .mini-item {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 14px;
        border: 1px solid #eef2f7;
        border-radius: 18px;
        background: #f8fafc;
    }

    /* Circular product image */
    .mini-thumb {
        width: 52px;
        height: 52px;
        border-radius: 50%;
        object-fit: cover;
        border: 2px solid #e2e8f0;
        background: #fff;
        flex-shrink: 0;
    }

    /* Placeholder when no image is available */
    .mini-thumb-placeholder {
        width: 52px;
        height: 52px;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: #94a3b8;
        border: 2px solid #e2e8f0;
        background: #fff;
        flex-shrink: 0;
    }

    /* Item title text */
    .mini-title {
        font-size: 0.98rem;
        font-weight: 800;
        color: #0f172a;
        margin-bottom: 3px;
    }

    /* Item subtitle text */
    .mini-subtitle {
        font-size: 0.88rem;
        color: #64748b;
        margin-bottom: 0;
    }

    /* Status/count badge */
    .mini-badge {
        margin-left: auto;
        border-radius: 999px;
        padding: 8px 12px;
        font-size: 0.8rem;
        font-weight: 800;
        white-space: nowrap;
    }

    /* Badge color variants */
    .badge-ok {
        background: rgba(22, 163, 74, 0.10);
        color: #16a34a;
    }

    .badge-critical {
        background: rgba(239, 68, 68, 0.10);
        color: #ef4444;
    }

    .badge-in {
        background: rgba(22, 163, 74, 0.10);
        color: #16a34a;
    }

    .badge-out {
        background: rgba(239, 68, 68, 0.10);
        color: #ef4444;
    }

    /* Alert box layout */
    .alert-box {
        padding: 18px 20px;
        border-radius: 18px;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    /* Critical alert style */
    .alert-critical {
        background: rgba(239, 68, 68, 0.08);
        color: #b91c1c;
        border: 1px solid rgba(239, 68, 68, 0.14);
    }

    /* Success/info alert style */
    .alert-ok {
        background: rgba(22, 163, 74, 0.08);
        color: #15803d;
        border: 1px solid rgba(22, 163, 74, 0.14);
    }

    /* Chart container */
    .chart-box {
        position: relative;
        width: 100%;
        height: 320px;
        min-height: 320px;
        max-height: 320px;
        overflow: hidden;
    }

        /* Medium chart height */
        .chart-box.chart-sm {
            height: 260px;
            min-height: 260px;
            max-height: 260px;
        }

        /* Small chart height */
        .chart-box.chart-xs {
            height: 220px;
            min-height: 220px;
            max-height: 220px;
        }

        /* Ensure canvas fills container */
        .chart-box canvas {
            width: 100% !important;
            height: 100% !important;
            display: block;
        }

    /* Empty state message */
    .empty-box {
        text-align: center;
        padding: 42px 10px;
        color: #64748b;
    }

    /* Mobile responsive adjustments */
    @@media (max-width: 576px) {
        .hero-card {
            padding: 24px;
        }

        .hero-title {
            font-size: 1.9rem;
        }

        .hero-actions {
            flex-direction: column;
            align-items: stretch;
        }

        .hero-btn {
            width: 100%;
        }
    }
</style>

<div class="container py-4">
    <!-- Dashboard hero section -->
    <div class="hero-card">
        <div class="hero-content">
            <div class="hero-text">
                <h1 class="hero-title">Dashboard</h1>
                <p class="hero-subtitle">
                    Sistemin genel durumunu, kritik stokları, son eklenen ürünleri ve hareket özetlerini tek ekrandan takip edebilirsin.
                </p>
            </div>

            <!-- Quick action buttons -->
            <div class="hero-actions">
                <a asp-controller="Product" asp-action="Create" class="btn btn-primary hero-btn">
                    <i class="bi bi-plus-lg me-2"></i>Yeni Ürün
                </a>
                <a asp-controller="StockMovement" asp-action="Create" class="btn btn-outline-dark hero-btn">
                    <i class="bi bi-arrow-left-right me-2"></i>Yeni Hareket
                </a>
                <a asp-controller="Supplier" asp-action="Create" class="btn btn-outline-secondary hero-btn">
                    <i class="bi bi-buildings me-2"></i>Tedarikçi Ekle
                </a>
            </div>
        </div>
    </div>

    <!-- Summary statistic cards -->
    <div class="row g-3 mb-4">
        <div class="col-md-6 col-xl-4">
            <div class="stats-card card-blue">
                <div class="stats-wrap">
                    <div class="stats-icon"><i class="bi bi-box-seam-fill"></i></div>
                    <div>
                        <div class="stats-label">Toplam Ürün</div>
                        <div class="stats-value">@totalProducts</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-xl-4">
            <div class="stats-card card-purple">
                <div class="stats-wrap">
                    <div class="stats-icon"><i class="bi bi-grid-1x2-fill"></i></div>
                    <div>
                        <div class="stats-label">Toplam Kategori</div>
                        <div class="stats-value">@totalCategories</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-xl-4">
            <div class="stats-card card-teal">
                <div class="stats-wrap">
                    <div class="stats-icon"><i class="bi bi-buildings-fill"></i></div>
                    <div>
                        <div class="stats-label">Toplam Tedarikçi</div>
                        <div class="stats-value">@totalSuppliers</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-xl-4">
            <div class="stats-card card-red">
                <div class="stats-wrap">
                    <div class="stats-icon"><i class="bi bi-exclamation-triangle-fill"></i></div>
                    <div>
                        <div class="stats-label">Kritik Stok</div>
                        <div class="stats-value">@criticalStockCount</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-xl-4">
            <div class="stats-card card-orange">
                <div class="stats-wrap">
                    <div class="stats-icon"><i class="bi bi-pause-circle-fill"></i></div>
                    <div>
                        <div class="stats-label">Pasif Ürün</div>
                        <div class="stats-value">@passiveProducts</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-xl-4">
            <div class="stats-card card-slate">
                <div class="stats-wrap">
                    <div class="stats-icon"><i class="bi bi-arrow-left-right"></i></div>
                    <div>
                        <div class="stats-label">Toplam Hareket</div>
                        <div class="stats-value">@totalMovements</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Critical stock and stock value alerts -->
    <div class="row g-4 mb-4">
        <div class="col-xl-8">
            @if (criticalStockCount > 0 || outOfStockCount > 0)
            {
                <div class="alert-box alert-critical">
                    <i class="bi bi-exclamation-octagon-fill"></i>
                    <span>
                        Kritik stokta <strong>@criticalStockCount</strong> ürün var.
                        Tükenen ürün sayısı: <strong>@outOfStockCount</strong>
                    </span>
                </div>
            }
            else
            {
                <div class="alert-box alert-ok">
                    <i class="bi bi-check-circle-fill"></i>
                    <span>Harika! Şu anda kritik stokta veya tükenen ürün bulunmuyor.</span>
                </div>
            }
        </div>

        <div class="col-xl-4">
            <div class="alert-box alert-ok h-100">
                <i class="bi bi-cash-stack"></i>
                <span>Toplam stok değeri: <strong>@totalStockValue.ToString("C")</strong></span>
            </div>
        </div>
    </div>

    <!-- Latest products and stock movements -->
    <div class="row g-4 mb-4">
        <div class="col-xl-6">
            <div class="panel-card">
                <div class="panel-header">
                    <div class="panel-title">Son Eklenen Ürünler</div>
                    <p class="panel-subtitle">Sisteme son eklenen ürün kayıtları</p>
                </div>

                <div class="panel-body">
                    @if (latestProducts.Any())
                    {
                        <div class="mini-list">
                            @foreach (var item in latestProducts)
                            {
                                // Check whether the product is currently at critical stock level
                                var isCritical = item.StockQuantity <= item.CriticalStockLevel;
                                <div class="mini-item">
                                    @if (!string.IsNullOrWhiteSpace(item.ImageUrl))
                                    {
                                        <img src="@item.ImageUrl" alt="@item.Name" class="mini-thumb" />
                                    }
                                    else
                                    {
                                        <div class="mini-thumb-placeholder">
                                            <i class="bi bi-image"></i>
                                        </div>
                                    }

                                    <div>
                                        <div class="mini-title">@item.Name</div>
                                        <p class="mini-subtitle">@(item.Category?.Name ?? "Kategori yok") • @item.UnitPrice.ToString("C")</p>
                                    </div>

                                    <span class="mini-badge @(isCritical ? "badge-critical" : "badge-ok")">
                                        Stok: @item.StockQuantity
                                    </span>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="empty-box">Henüz ürün kaydı bulunmuyor.</div>
                    }
                </div>
            </div>
        </div>

        <div class="col-xl-6">
            <div class="panel-card">
                <div class="panel-header">
                    <div class="panel-title">Son Stok Hareketleri</div>
                    <p class="panel-subtitle">En son eklenen giriş ve çıkış hareketleri</p>
                </div>

                <div class="panel-body">
                    @if (latestMovements.Any())
                    {
                        <div class="mini-list">
                            @foreach (var item in latestMovements)
                            {
                                <div class="mini-item">
                                    @if (!string.IsNullOrWhiteSpace(item.Product?.ImageUrl))
                                    {
                                        <img src="@item.Product.ImageUrl" alt="@item.Product.Name" class="mini-thumb" />
                                    }
                                    else
                                    {
                                        <div class="mini-thumb-placeholder">
                                            <i class="bi bi-box"></i>
                                        </div>
                                    }

                                    <div>
                                        <div class="mini-title">@item.Product?.Name</div>
                                        <p class="mini-subtitle">@item.MovementDate.ToString("dd.MM.yyyy HH:mm")</p>
                                    </div>

                                    <span class="mini-badge @(item.MovementType == "In" ? "badge-in" : "badge-out")">
                                        @(item.MovementType == "In" ? "Giriş" : "Çıkış") • @item.Quantity
                                    </span>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="empty-box">Henüz stok hareketi bulunmuyor.</div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Latest audit logs -->
    <div class="row g-4 mb-4">
        <div class="col-12">
            <div class="panel-card">
                <div class="panel-header">
                    <div class="panel-title">Son İşlemler</div>
                    <p class="panel-subtitle">Sistemde yapılan son kayıtlı işlemler</p>
                </div>

                <div class="panel-body">
                    @if (latestAuditLogs.Any())
                    {
                        <div class="mini-list">
                            @foreach (var item in latestAuditLogs)
                            {
                                <div class="mini-item">
                                    <div class="mini-thumb-placeholder">
                                        <i class="bi bi-clock-history"></i>
                                    </div>

                                    <div>
                                        <div class="mini-title">@item.ActionType • @item.EntityName</div>
                                        <p class="mini-subtitle">@item.Description</p>
                                    </div>

                                    <span class="mini-badge badge-ok">
                                        @item.CreatedDate.ToString("dd.MM HH:mm")
                                    </span>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="empty-box">Henüz log kaydı bulunmuyor.</div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Low stock products and overall system summary -->
    <div class="row g-4 mb-4">
        <div class="col-xl-6">
            <div class="panel-card">
                <div class="panel-header">
                    <div class="panel-title">En Düşük Stoklu Ürünler</div>
                    <p class="panel-subtitle">Kritik seviyeye yaklaşan veya düşen ürünler</p>
                </div>

                <div class="panel-body">
                    @if (lowStockProducts.Any())
                    {
                        <div class="mini-list">
                            @foreach (var item in lowStockProducts)
                            {
                                <div class="mini-item">
                                    @if (!string.IsNullOrWhiteSpace(item.ImageUrl))
                                    {
                                        <img src="@item.ImageUrl" alt="@item.Name" class="mini-thumb" />
                                    }
                                    else
                                    {
                                        <div class="mini-thumb-placeholder">
                                            <i class="bi bi-exclamation"></i>
                                        </div>
                                    }

                                    <div>
                                        <div class="mini-title">@item.Name</div>
                                        <p class="mini-subtitle">
                                            @(item.Category?.Name ?? "Kategori yok") • Kritik: @item.CriticalStockLevel
                                        </p>
                                    </div>

                                    <span class="mini-badge badge-critical">
                                        Stok: @item.StockQuantity
                                    </span>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="empty-box">Kritik stok ürünü bulunmuyor.</div>
                    }
                </div>
            </div>
        </div>

        <div class="col-xl-6">
            <div class="panel-card">
                <div class="panel-header">
                    <div class="panel-title">Sistem Özeti</div>
                    <p class="panel-subtitle">Temel sayısal görünüm</p>
                </div>

                <div class="panel-body">
                    <div class="mini-list">
                        <div class="mini-item">
                            <div class="mini-thumb-placeholder"><i class="bi bi-check-circle"></i></div>
                            <div>
                                <div class="mini-title">Aktif Ürün</div>
                                <p class="mini-subtitle">Sistemde aktif olan ürün sayısı</p>
                            </div>
                            <span class="mini-badge badge-ok">@activeProducts</span>
                        </div>

                        <div class="mini-item">
                            <div class="mini-thumb-placeholder"><i class="bi bi-pause-circle"></i></div>
                            <div>
                                <div class="mini-title">Pasif Ürün</div>
                                <p class="mini-subtitle">Geçici olarak devre dışı ürünler</p>
                            </div>
                            <span class="mini-badge badge-critical">@passiveProducts</span>
                        </div>

                        <div class="mini-item">
                            <div class="mini-thumb-placeholder"><i class="bi bi-archive"></i></div>
                            <div>
                                <div class="mini-title">Tükenen Ürün</div>
                                <p class="mini-subtitle">Stoğu sıfır olan ürünler</p>
                            </div>
                            <span class="mini-badge badge-critical">@outOfStockCount</span>
                        </div>

                        <div class="mini-item">
                            <div class="mini-thumb-placeholder"><i class="bi bi-cash"></i></div>
                            <div>
                                <div class="mini-title">Toplam Stok Değeri</div>
                                <p class="mini-subtitle">Tüm ürünlerin yaklaşık stok değeri</p>
                            </div>
                            <span class="mini-badge badge-ok">@totalStockValue.ToString("C")</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Main charts section -->
    <div class="row g-4 mb-4">
        <div class="col-xl-7">
            <div class="panel-card">
                <div class="panel-header">
                    <div class="panel-title">Kategoriye Göre Ürün Dağılımı</div>
                    <p class="panel-subtitle">Hangi kategoride kaç ürün olduğunu gösterir</p>
                </div>
                <div class="panel-body">
                    <div class="chart-box">
                        <canvas id="categoryChart"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-5">
            <div class="panel-card">
                <div class="panel-header">
                    <div class="panel-title">Giriş / Çıkış Özeti</div>
                    <p class="panel-subtitle">Toplam hareket tipi dağılımı</p>
                </div>
                <div class="panel-body">
                    <div class="chart-box chart-sm">
                        <canvas id="movementChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Trend analysis charts -->
    <div class="row g-4">
        <div class="col-xl-6">
            <div class="panel-card">
                <div class="panel-header">
                    <div class="panel-title">Son 7 Gün Hareket Sayısı</div>
                    <p class="panel-subtitle">Günlük işlem yoğunluğu</p>
                </div>
                <div class="panel-body">
                    <div class="chart-box chart-xs">
                        <canvas id="dailyMovementChart"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3">
            <div class="panel-card">
                <div class="panel-header">
                    <div class="panel-title">Aylık Hareketler</div>
                    <p class="panel-subtitle">Bu yılın aylık hareket dağılımı</p>
                </div>
                <div class="panel-body">
                    <div class="chart-box chart-xs">
                        <canvas id="monthlyMovementChart"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3">
            <div class="panel-card">
                <div class="panel-header">
                    <div class="panel-title">Yıllık Hareketler</div>
                    <p class="panel-subtitle">Yıllara göre toplam hareket</p>
                </div>
                <div class="panel-body">
                    <div class="chart-box chart-xs">
                        <canvas id="yearlyMovementChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // Raw chart data received from Razor variables
        const categoryLabels = @Html.Raw(categoryLabels);
        const categoryCounts = @Html.Raw(categoryCounts);
        const movementLabels = @Html.Raw(movementLabels);
        const movementCounts = @Html.Raw(movementCounts);
        const dailyMovementLabels = @Html.Raw(dailyMovementLabels);
        const dailyMovementCounts = @Html.Raw(dailyMovementCounts);
        const monthlyMovementLabels = @Html.Raw(monthlyMovementLabels);
        const monthlyMovementCounts = @Html.Raw(monthlyMovementCounts);
        const yearlyMovementLabels = @Html.Raw(yearlyMovementLabels);
        const yearlyMovementCounts = @Html.Raw(yearlyMovementCounts);

        // Creates the category distribution bar chart
        function createCategoryChart() {
            const el = document.getElementById("categoryChart");
            if (!el) return;

            new Chart(el, {
                type: "bar",
                data: {
                    labels: categoryLabels,
                    datasets: [{
                        label: "Ürün Sayısı",
                        data: categoryCounts,
                        borderRadius: 10,
                        borderWidth: 1
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    animation: false,
                    plugins: {
                        legend: { display: false }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            ticks: { precision: 0 }
                        }
                    }
                }
            });
        }

        // Creates the stock movement doughnut chart
        function createMovementChart() {
            const el = document.getElementById("movementChart");
            if (!el) return;

            new Chart(el, {
                type: "doughnut",
                data: {
                    labels: movementLabels,
                    datasets: [{
                        data: movementCounts,
                        borderWidth: 0
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    animation: false
                }
            });
        }

        // Creates the daily stock movement trend line chart
        function createDailyMovementChart() {
            const el = document.getElementById("dailyMovementChart");
            if (!el) return;

            new Chart(el, {
                type: "line",
                data: {
                    labels: dailyMovementLabels,
                    datasets: [{
                        label: "Günlük Hareket",
                        data: dailyMovementCounts,
                        fill: false,
                        tension: 0.35,
                        borderWidth: 3
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    animation: false,
                    plugins: {
                        legend: { display: false }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            ticks: { precision: 0 }
                        }
                    }
                }
            });
        }

        // Creates the monthly stock movement bar chart
        function createMonthlyMovementChart() {
            const el = document.getElementById("monthlyMovementChart");
            if (!el) return;

            new Chart(el, {
                type: "bar",
                data: {
                    labels: monthlyMovementLabels,
                    datasets: [{
                        label: "Aylık Hareket",
                        data: monthlyMovementCounts,
                        borderRadius: 8,
                        borderWidth: 1
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    animation: false,
                    plugins: {
                        legend: { display: false }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            ticks: { precision: 0 }
                        }
                    }
                }
            });
        }

        // Creates the yearly stock movement bar chart
        function createYearlyMovementChart() {
            const el = document.getElementById("yearlyMovementChart");
            if (!el) return;

            new Chart(el, {
                type: "bar",
                data: {
                    labels: yearlyMovementLabels,
                    datasets: [{
                        label: "Yıllık Hareket",
                        data: yearlyMovementCounts,
                        borderRadius: 8,
                        borderWidth: 1
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    animation: false,
                    plugins: {
                        legend: { display: false }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            ticks: { precision: 0 }
                        }
                    }
                }
            });
        }

        // Initialize all dashboard charts
        createCategoryChart();
        createMovementChart();
        createDailyMovementChart();
        createMonthlyMovementChart();
        createYearlyMovementChart();
    </script>
}